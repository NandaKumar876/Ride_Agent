# DriverAgent environment variables
# Copy this to .env.local

# URL of the Rider Agent
RIDER_AGENT_URL=http://localhost:3000

# GOAT x402 API
GOATX402_API_URL=https://x402-api-lx58aabp0r.testnet3.goat.network
GOATX402_MERCHANT_ID=driver_nanda
GOATX402_API_KEY=<your-api-key>
GOATX402_API_SECRET=<your-api-secret — BACKEND ONLY>

# Driver wallet private key — BACKEND ONLY, never expose to frontend
DRIVER_PRIVATE_KEY=<your-private-key>
