# RiderAgent environment variables
# Copy this to .env.local

# URL of the Driver Agent (change if deployed remotely)
DRIVER_AGENT_URL=http://localhost:3001
NEXT_PUBLIC_DRIVER_URL=http://localhost:3001

# GOAT x402 API
GOATX402_API_URL=https://x402-api-lx58aabp0r.testnet3.goat.network
GOATX402_MERCHANT_ID=rider_nanda
GOATX402_API_KEY=<your-api-key>
GOATX402_API_SECRET=<your-api-secret — BACKEND ONLY, never prefix with NEXT_PUBLIC_>

# Rider wallet private key — NEVER commit to git
# Used server-side only to sign EIP-712 permits
RIDER_PRIVATE_KEY=<your-private-key>
